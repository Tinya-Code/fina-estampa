---
import { Icon } from 'astro-icon/components';

interface HeroSlide {
	image: string;
	logo?: string;
	title?: string;
	subtitle?: string;
	description?: string;
	cta?: {
		text: string;
		link: string;
		icon?: string;
		variant?: 'primary' | 'secondary' | 'outline';
	};
	ctaSecondary?: {
		text: string;
		link: string;
		icon?: string;
		variant?: 'primary' | 'secondary' | 'outline';
	};
}

interface HeroProps {
	slides: HeroSlide[];
	autoSlide?: boolean;
	autoSlideInterval?: number;
	showDots?: boolean;
	showArrows?: boolean;
	height?: string;
	overlay?: boolean;
	overlayOpacity?: number;
}

const {
	slides,
	autoSlide = false,
	autoSlideInterval = 5000,
	showDots = true,
	showArrows = true,
	height = 'h-[600px]',
	overlay = true,
	overlayOpacity = 0.5,
} = Astro.props as HeroProps;

const isSlider = slides.length > 1;
---

<div class={`relative overflow-hidden w-screen ${height}`} id="hero-slider">
	<!-- Slides Container -->
	<div class="relative h-full">
		{slides.map((slide, index) => (
			<div
				class={`absolute inset-0 transition-opacity duration-500 ease-in-out ${
					index === 0 ? 'opacity-100 z-10' : 'opacity-0 z-0'
				} hero-slide`}
				data-index={index}
			>
				<!-- Background Image -->
				<img
					src={slide.image}
					alt={slide.title || 'Hero slide'}
					class="w-full h-full object-cover"
					loading={index === 0 ? 'eager' : 'lazy'}
				/>
				
				<!-- Overlay -->
				{overlay && (
					<div
						class="absolute inset-0 bg-black"
						style={`opacity: ${overlayOpacity}`}
					></div>
				)}
				
				<!-- Content -->
				<div class="absolute inset-0 flex items-center justify-center z-20">
					<div class="text-center px-4 max-w-4xl">
						{slide.logo && (
							<img
								src={slide.logo}
								alt="Logo"
								class="w-24 h-24 md:w-32 md:h-32 mx-auto mb-6 object-contain"
							/>
						)}
						{slide.title && (
							<h1 class="font-display text-4xl md:text-6xl font-bold text-white mb-4 drop-shadow-lg">
								{slide.title}
							</h1>
						)}
						{slide.subtitle && (
							<h2 class="font-body text-2xl md:text-3xl text-white mb-4 drop-shadow-md">
								{slide.subtitle}
							</h2>
						)}
						{slide.description && (
							<p class="font-body text-lg md:text-xl text-gray-200 mb-8 drop-shadow-md max-w-2xl mx-auto">
								{slide.description}
							</p>
						)}
						
						<!-- CTAs -->
						{(slide.cta || slide.ctaSecondary) && (
							<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
								{slide.cta && (
									<a
										href={slide.cta.link}
										class={`inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold transition-all hover:scale-105 ${
											slide.cta.variant === 'secondary'
												? 'bg-amber-600 text-white hover:bg-amber-700'
												: slide.cta.variant === 'outline'
												? 'border-2 border-white text-white hover:bg-white hover:text-gray-900'
												: 'bg-orange-600 text-white hover:bg-orange-700'
										}`}
									>
										{slide.cta.icon && (
											<Icon name={slide.cta.icon} />
										)}
										<span class="font-body">{slide.cta.text}</span>
									</a>
								)}
								{slide.ctaSecondary && (
									<a
										href={slide.ctaSecondary.link}
										class={`inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold transition-all hover:scale-105 ${
											slide.ctaSecondary.variant === 'secondary'
												? 'bg-amber-600 text-white hover:bg-amber-700'
												: slide.ctaSecondary.variant === 'outline'
												? 'border-2 border-white text-white hover:bg-white hover:text-gray-900'
												: 'bg-orange-600 text-white hover:bg-orange-700'
										}`}
									>
										{slide.ctaSecondary.icon && (
											<Icon name={slide.ctaSecondary.icon} />
										)}
										<span class="font-body">{slide.ctaSecondary.text}</span>
									</a>
								)}
							</div>
						)}
					</div>
				</div>
			</div>
		))}
	</div>
	
	<!-- Navigation Arrows -->
	{isSlider && showArrows && (
		<>
			<button
				class="absolute left-4 top-1/2 -translate-y-1/2 z-30 bg-white/20 hover:bg-white/40 backdrop-blur-sm p-3 rounded-full transition-all hover:scale-110"
				aria-label="Previous slide"
				id="hero-prev"
			>
				<Icon name="lucide:chevron-left" class="text-white text-2xl" />
			</button>
			<button
				class="absolute right-4 top-1/2 -translate-y-1/2 z-30 bg-white/20 hover:bg-white/40 backdrop-blur-sm p-3 rounded-full transition-all hover:scale-110"
				aria-label="Next slide"
				id="hero-next"
			>
				<Icon name="lucide:chevron-right" class="text-white text-2xl" />
			</button>
		</>
	)}
	
	<!-- Dots Navigation -->
	{isSlider && showDots && (
		<div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex gap-3" id="hero-dots">
			{slides.map((_, index) => (
				<button
					class={`w-3 h-3 rounded-full transition-all ${
						index === 0 ? 'bg-white scale-125' : 'bg-white/50 hover:bg-white/80'
					}`}
					aria-label={`Go to slide ${index + 1}`}
					data-index={index}
				></button>
			))}
		</div>
	)}
</div>

{isSlider && (
	<script define:vars={{ autoSlide, autoSlideInterval }}>
		let currentIndex = 0;
		let autoSlideTimer = null;
		
		const slides = document.querySelectorAll('.hero-slide');
		const dots = document.querySelectorAll('#hero-dots button');
		const prevBtn = document.getElementById('hero-prev');
		const nextBtn = document.getElementById('hero-next');
		
		function goToSlide(index) {
			// Update slides
			slides.forEach((slide, i) => {
				if (i === index) {
					slide.classList.remove('opacity-0', 'z-0');
					slide.classList.add('opacity-100', 'z-10');
				} else {
					slide.classList.remove('opacity-100', 'z-10');
					slide.classList.add('opacity-0', 'z-0');
				}
			});
			
			// Update dots
			dots.forEach((dot, i) => {
				if (i === index) {
					dot.classList.remove('bg-white/50', 'hover:bg-white/80');
					dot.classList.add('bg-white', 'scale-125');
				} else {
					dot.classList.remove('bg-white', 'scale-125');
					dot.classList.add('bg-white/50', 'hover:bg-white/80');
				}
			});
			
			currentIndex = index;
		}
		
		function nextSlide() {
			const nextIndex = (currentIndex + 1) % slides.length;
			goToSlide(nextIndex);
		}
		
		function prevSlide() {
			const prevIndex = (currentIndex - 1 + slides.length) % slides.length;
			goToSlide(prevIndex);
		}
		
		// Event listeners
		if (prevBtn) {
			prevBtn.addEventListener('click', () => {
				prevSlide();
				resetAutoSlide();
			});
		}
		
		if (nextBtn) {
			nextBtn.addEventListener('click', () => {
				nextSlide();
				resetAutoSlide();
			});
		}
		
		dots.forEach((dot, index) => {
			dot.addEventListener('click', () => {
				goToSlide(index);
				resetAutoSlide();
			});
		});
		
		// Auto slide
		function startAutoSlide() {
			if (autoSlide && autoSlideInterval > 0) {
				autoSlideTimer = window.setInterval(() => {
					nextSlide();
				}, autoSlideInterval);
			}
		}
		
		function stopAutoSlide() {
			if (autoSlideTimer) {
				clearInterval(autoSlideTimer);
				autoSlideTimer = null;
			}
		}
		
		function resetAutoSlide() {
			stopAutoSlide();
			startAutoSlide();
		}
		
		// Start auto slide on load
		startAutoSlide();
		
		// Pause on hover
		const slider = document.getElementById('hero-slider');
		if (slider && autoSlide) {
			slider.addEventListener('mouseenter', stopAutoSlide);
			slider.addEventListener('mouseleave', startAutoSlide);
		}
		
		// Cleanup
		document.addEventListener('astro:unmount', () => {
			stopAutoSlide();
		});
	</script>
)}
