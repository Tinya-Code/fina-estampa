---
import SectionTitle from "../../components/SectionTitle.astro";
import { Icon } from "astro-icon/components";

const foodData = {
  title: "Tradición y sabor en cada plato",
  images: [
    {
      src: "/images/food/arroz-con-pollo.png",
      alt: "Arroz con pollo",
    },
    {
      src: "/images/food/ceviche.png",
      alt: "Ceviche",
    },
    {
      src: "/images/food/seco-con-frejoles.png",
      alt: "Seco con frejoles",
    },
  ],
  contactButton: {
    text: "Menu",
    link: "/menu-desayunos-cocteles/",
  },
};
---

<section class="flex bg-surface py-6 px-0 md:px-6">
  <div class="flex max-w-6xl mx-auto">
    <div class="flex-1 flex flex-col items-center gap-6">
 
          <SectionTitle
        title={foodData.title}
    />

      <div class="w-full flex-1 grid grid-cols-1 md:grid-cols-3 gap-2">
        {foodData.images.map((image) => (
          <div class="col-span-1 flex flex-col gap-2">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-48 md:h-full object-cover"
            />
          </div>
        ))}
      </div>

          <div>
          <a
            href={foodData.contactButton.link}
            class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3 font-body font-semibold text-white hover:scale-[1.02] transition-transform"
          >
            <Icon name="lucide:utensils" class="size-5" />
            {foodData.contactButton.text}
          </a>
        </div>
    </div>
  </div>
</section>
