---
import SectionTitle from "../../components/SectionTitle.astro";
import { Icon } from "astro-icon/components";

const barData = {
  title: "Cócteles y momentos inolvidables",
  description:
    "Disfruta de una variada carta de cócteles, bebidas y piqueos en un ambiente ideal para reunirse con amigos y familiares. Nuestro restobar es el lugar perfecto para relajarse, celebrar y acompañar cada momento con buena música y una atención excepcional.",
  menuButton: {
    text: "Ver menú",
    link: "/menu",
  },
  contactButton: {
    text: "Menu",
    link: "/menu-desayunos-cocteles",
  },
  images: [
    {
      src: "/images/drinks/coctel-algarrobina.jpg",
      alt: "Coctel con algarrobina",
    },
    {
      src: "/images/drinks/pisco-sour.jpg",
      alt: "Pisco sour",
    },
  ],
};
---

<section class="flex bg-surface  py-6 px-0 md:py-12">
  <div class="flex max-w-6xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div class="flex flex-col mx-auto max-w-md gap-4 ">
        <SectionTitle
          title={barData.title}
          align="left"
        />


        <p class=" font-body  text-primary/80 mb-6">
          {barData.description}
        </p>

         <div>
          <a
            href={barData.contactButton.link}
            class="inline-flex items-center gap-2 rounded-full bg-accent px-7 py-3 font-body font-semibold text-white hover:scale-[1.02] transition-transform"
          >
            <Icon name="lucide:calendar-check" class="size-5" />
            {barData.contactButton.text}
          </a>
        </div>
      </div>
      <div class="flex flex-col gap-2">
        {barData.images.map((image) => (
          <img
            src={image.src}
            alt={image.alt}
            class="max-h-60 object-cover"
          />
        ))}
      </div>
    </div>
  </div>
</section>
