---
// ──────────────────────────────────────────────
// Objeto de configuración de navegación
// ──────────────────────────────────────────────
const navConfig = {
  logo: {
    src: "/fina-logo.svg",
    alt: "Fina Estampa",
    width: 48,
    height: 48,
  },
  links: [
    { label: "Inicio", href: "/" },
    { label: "Menú", href: "/menu-desayunos-cocteles" },
    { label: "Historia", href: "/historia-fina-estampa" },
    { label: "Eventos", href: "/eventos-cieneguilla" },
    { label: "La Fina", href: "/la-fina-cieneguilla" },
    { label: "Contacto", href: "/contacto-fina-estampa" },
  ],
  cta: {
    label: "Reservaciones",
    href: "/contacto-fina-estampa",
  },
  contact: {
    email: "contacto@finaestampa.pe",
  },
};

const currentPath = Astro.url.pathname;
---

<!-- ══════════════════════════════════════════
     HEADER FIJO
════════════════════════════════════════════ -->
<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-40 transition-[background,backdrop-filter,box-shadow] duration-300"
>
  <div class="max-w-7xl mx-auto px-6 h-[70px] flex items-center gap-8">
    <!-- Logo -->
    <a
      href="/"
      aria-label="Fina Estampa - Inicio"
      class="flex items-center gap-2.5 no-underline flex-shrink-0 group"
    >
      <img
        src={navConfig.logo.src}
        alt={navConfig.logo.alt}
        width={navConfig.logo.width}
        height={navConfig.logo.height}
        class="w-30 h-auto object-contain transition-opacity duration-200 group-hover:opacity-75"
      />
    </a>

    <!-- Desktop nav (oculto en móvil) -->
    <nav
      class="hidden md:flex justify-center"
      aria-label="Navegación principal"
    >
      <ul role="list" class="flex gap-1 list-none m-0 p-0">
        {
          navConfig.links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "block px-3 py-1.5 text-sm font-medium rounded-md tracking-wide transition-colors duration-200 no-underline",
                  currentPath === link.href
                    ? "text-white bg-white/10"
                    : "text-white/80 hover:text-white hover:bg-white/10",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Acciones: CTA desktop + hamburger -->
    <div class="flex items-center gap-4 ml-auto">
      <!-- CTA solo en desktop -->
      <a
        href={navConfig.cta.href}
        class="hidden md:inline-flex items-center px-4 py-1.5 rounded-full border border-white/60 text-sm font-medium text-white no-underline tracking-wide transition-[background,border-color,color] duration-200 hover:bg-white hover:text-[#1a1612] hover:border-white"
      >
        {navConfig.cta.label}
      </a>

      <!-- Hamburger (solo móvil) -->
      <button
        id="menu-toggle"
        class="flex md:hidden flex-col justify-center gap-[5px] w-8 h-8 bg-transparent border-0 cursor-pointer p-0.5"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span
          id="ham-1"
          class="block w-full h-[1.5px] bg-white rounded-sm origin-center transition-transform duration-300"
        ></span>
        <span
          id="ham-2"
          class="block w-full h-[1.5px] bg-white rounded-sm origin-center transition-[transform,opacity] duration-300"
        ></span>
        <span
          id="ham-3"
          class="block w-full h-[1.5px] bg-white rounded-sm origin-center transition-transform duration-300"
        ></span>
      </button>
    </div>
  </div>
</header>

<!-- ══════════════════════════════════════════
     PANEL LATERAL MÓVIL (slide desde la izquierda)
════════════════════════════════════════════ -->

<!-- Overlay oscuro detrás del panel -->
<div
  id="menu-overlay"
  class="fixed inset-0 z-[110] bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300"
  aria-hidden="true"
>
</div>

<!-- Panel -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 z-[120] h-full w-[280px] bg-white shadow-2xl translate-x-full transition-transform duration-300 ease-in-out flex flex-col"
  aria-hidden="true"
  role="dialog"
  aria-label="Menú de navegación"
>
  <!-- Cabecera del panel: logo + botón cerrar -->
  <div class="flex items-center justify-end px-6 pt-6">
    <button
      id="menu-close"
      class="flex items-center justify-center w-8 h-8 rounded-full text-gray-400 hover:text-red-700 hover:bg-red-50 transition-colors duration-200 cursor-pointer border-0 bg-transparent"
      aria-label="Cerrar menú"
    >
      <!-- X icon -->
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line><line
          x1="6"
          y1="6"
          x2="18"
          y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Links de navegación -->
  <nav class="flex-1 px-4 py-4 overflow-y-auto" aria-label="Navegación móvil">
    <ul role="list" class="list-none m-0 p-0 flex flex-col">
      {
        navConfig.links.map((link) => (
          <li>
            <a
              href={link.href}
              class:list={[
                "flex items-center px-4 py-3.5 text-base font-semibold tracking-wide no-underline rounded-lg transition-colors duration-150 border-b border-gray-100 last:border-b-0",
                currentPath === link.href
                  ? "text-red-700 bg-red-50"
                  : "text-red-700 hover:text-red-800 hover:bg-red-50",
              ]}
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Pie del panel: email + CTA reservaciones -->
  <div
    class="px-6 py-5 border-t border-gray-100 bg-gray-50 flex flex-col gap-3"
  >
    <!-- Email -->
    <a
      href={`mailto:${navConfig.contact.email}`}
      class="flex items-center gap-2 text-xs text-gray-500 no-underline hover:text-red-700 transition-colors duration-150"
    >
      <!-- Envelope icon -->
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="2" y="4" width="20" height="16" rx="2"></rect><polyline
          points="2,4 12,13 22,4"></polyline>
      </svg>
      <span>{navConfig.contact.email}</span>
    </a>

    <!-- CTA Reservaciones -->
    <a
      href={navConfig.cta.href}
      class="flex items-center justify-center gap-2 w-full py-3 px-4 rounded-xl bg-red-700 text-white font-bold text-sm tracking-widest uppercase no-underline shadow-md hover:bg-red-800 active:scale-95 transition-[background,transform] duration-150"
      id="panel-cta"
    >
      <!-- Calendar icon -->
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect x="3" y="4" width="18" height="18" rx="2"></rect><line
          x1="16"
          y1="2"
          x2="16"
          y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line
          x1="3"
          y1="10"
          x2="21"
          y2="10"></line>
      </svg>
      {navConfig.cta.label}
    </a>
  </div>
</div>

<script>
  const header = document.getElementById("site-header")!;
  const toggle = document.getElementById("menu-toggle")!;
  const closeBtn = document.getElementById("menu-close")!;
  const mobileMenu = document.getElementById("mobile-menu")!;
  const overlay = document.getElementById("menu-overlay")!;

  const ham1 = document.getElementById("ham-1")!;
  const ham2 = document.getElementById("ham-2")!;
  const ham3 = document.getElementById("ham-3")!;

  // ── Scroll: clase "scrolled" ──────────────────
  function onScroll() {
    if (window.scrollY > 20) {
      header.classList.add(
        "bg-[rgba(10,8,6,0.85)]",
        "backdrop-blur-[14px]",
        "shadow-[0_1px_0_rgba(255,255,255,0.06)]",
      );
    } else {
      header.classList.remove(
        "bg-[rgba(10,8,6,0.85)]",
        "backdrop-blur-[14px]",
        "shadow-[0_1px_0_rgba(255,255,255,0.06)]",
      );
    }
  }
  window.addEventListener("scroll", onScroll, { passive: true });
  onScroll();

  // ── Abrir / cerrar panel ──────────────────────
  function openMenu() {
    mobileMenu.classList.remove("translate-x-full");
    mobileMenu.setAttribute("aria-hidden", "false");
    overlay.classList.remove("opacity-0", "pointer-events-none");
    overlay.classList.add("opacity-100");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";

    // Animar hamburger → X
    ham1.style.transform = "translateY(6.5px) rotate(45deg)";
    ham2.style.opacity = "0";
    ham2.style.transform = "scaleX(0)";
    ham3.style.transform = "translateY(-6.5px) rotate(-45deg)";
  }

  function closeMenu() {
    mobileMenu.classList.add("translate-x-full");
    mobileMenu.setAttribute("aria-hidden", "true");
    overlay.classList.add("opacity-0", "pointer-events-none");
    overlay.classList.remove("opacity-100");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";

    // Reset hamburger
    ham1.style.transform = "";
    ham2.style.opacity = "";
    ham2.style.transform = "";
    ham3.style.transform = "";
  }

  toggle.addEventListener("click", () => {
    const isOpen = !mobileMenu.classList.contains("translate-x-full");
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn.addEventListener("click", closeMenu);
  overlay.addEventListener("click", closeMenu);

  // Cerrar al hacer click en cualquier enlace del panel
  mobileMenu.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
