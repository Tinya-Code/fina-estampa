---
import { Icon } from "astro-icon/components";

// ──────────────────────────────────────────────
// Props: variant controls header display mode
//   "full"    → Logo + Nav links + CTA + Hamburger (default)
//   "minimal" → Only hamburger button visible; drawer still works
// ──────────────────────────────────────────────
interface Props {
  variant?: "full" | "minimal";
}

const { variant = "full" } = Astro.props;
const isMinimal = variant === "minimal";

// ──────────────────────────────────────────────
// Configuration object with metadata, icons, and subtitles
// ──────────────────────────────────────────────
const navConfig = {
  logo: {
    src: "/fina-logo.svg",
    alt: "Fina Estampa Logo",
    width: 48,
    height: 48,
  },
  links: [
    { label: "Inicio", href: "/", icon: "lucide:home", subtitle: "Página principal" },
    { label: "Menú", href: "/menu-desayunos-cocteles", icon: "lucide:utensils-crossed", subtitle: "Nuestras delicias" },
    { label: "Historia", href: "/historia-fina-estampa", icon: "lucide:book-open", subtitle: "Nuestra trayectoria" },
    { label: "Eventos", href: "/eventos-cieneguilla", icon: "lucide:party-popper", subtitle: "Celebraciones únicas" },
    { label: "La Fina", href: "/la-fina-cieneguilla", icon: "lucide:compass", subtitle: "Sede Cieneguilla" },
    { label: "Contacto", href: "/contacto-fina-estampa", icon: "lucide:mail", subtitle: "Escríbenos" },
  ],
  cta: {
    label: "Reservaciones",
    href: "/contacto-fina-estampa",
    icon: "lucide:calendar-days"
  },
  socials: [
    { name: "Instagram", href: "https://instagram.com/finaestampa", icon: "lucide:instagram" },
    { name: "WhatsApp", href: "https://wa.me/51942235532", icon: "lucide:message-circle-code" }
  ],
  contact: {
    email: "contacto@finaestampa.pe",
    phone: "+51 942 235 532",
    address: "Cieneguilla, Lima, Perú"
  },
};

const currentPath = Astro.url.pathname;
const cleanPath = currentPath.replace(/\/$/, "");
---

<!-- ══════════════════════════════════════════
     FLOATING CAPSULE HEADER
     ════════════════════════════════════════════ -->
<header
  id="site-header"
  class:list={[
    "fixed top-0 mt-2 left-0 right-0 z-50 transition-all duration-500",
    isMinimal ? "flex items-start justify-end px-4 md:px-8 py-3" : "px-4 md:px-8"
  ]}
>
  {isMinimal ? (
    <!-- ── MINIMAL VARIANT: Only hamburger button ── -->
    <button
      id="menu-toggle"
      class="flex flex-col justify-center items-center w-11 h-11 bg-primary/80 backdrop-blur-xl hover:bg-primary border border-white/10 rounded-full cursor-pointer transition-all duration-300 shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:shadow-[0_6px_25px_rgba(0,0,0,0.4)]"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <div class="flex flex-col gap-[4px] w-5">
        <span id="ham-1" class="block w-full h-[1.5px] bg-white rounded-full origin-center transition-transform duration-300"></span>
        <span id="ham-2" class="block w-full h-[1.5px] bg-white rounded-full origin-center transition-[transform,opacity] duration-300"></span>
        <span id="ham-3" class="block w-full h-[1.5px] bg-white rounded-full origin-center transition-transform duration-300"></span>
      </div>
    </button>
  ) : (
    <!-- ── FULL VARIANT: Complete header bar ── -->
    <div
      id="header-container"
      class="max-w-7xl mx-auto backdrop-blur-xl border border-white/10 rounded-2xl md:rounded-full px-4 flex items-center justify-between transition-all duration-500 relative bg-primary/92 h-14 md:h-16 border-white/15"
    >
      <!-- Logo & Brand -->
      <a
        href="/"
        aria-label="Fina Estampa - Inicio"
        class="flex items-center gap-3 no-underline flex-shrink-0 group relative z-10"
      >
        <img
          src={navConfig.logo.src}
          alt={navConfig.logo.alt}
          width={navConfig.logo.width}
          height={navConfig.logo.height}
          class="h-10 md:h-12 w-auto object-contain transition-all duration-300 group-hover:scale-105"
        />
      </a>

      <!-- Desktop Navigation Links -->
      <nav
        class="hidden md:flex items-center justify-center  "
        aria-label="Navegación principal"
      >
        <ul role="list" class="flex justify-center gap-1.5 list-none m-0 p-0">
          {
            navConfig.links.map((link) => {
              const isLinkActive = cleanPath === link.href.replace(/\/$/, "") || (link.href === "/" && cleanPath === "");
              return (
                <li>
                  <a
                    href={link.href}
                    class:list={[
                      "relative block px-4 py-2 text-xs lg:text-sm font-display tracking-wider uppercase rounded-full transition-all duration-300 no-underline overflow-hidden group",
                      isLinkActive
                        ? "text-white bg-white/10 font-bold"
                        : "text-white/80 hover:text-white hover:bg-white/5",
                    ]}
                  >
                    <span class="relative z-10 flex items-center gap-1.5">
                      {link.label}
                    </span>
                    {isLinkActive && (
                      <span class="absolute bottom-1 left-1/2 -translate-x-1/2 w-5 h-0.5 bg-accent rounded-full" />
                    )}
                  </a>
                </li>
              );
            })
          }
        </ul>
      </nav>

      <!-- Right Side Actions (CTA + Socials + Hamburger) -->
      <div class="flex items-center gap-3 relative z-10">
        <!-- Socials (Desktop only) -->
        <div class="hidden lg:flex items-center gap-2 mr-1">
          {navConfig.socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="w-9 h-9 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/70 hover:text-accent hover:bg-white/10 hover:border-accent/30 transition-all duration-300"
              aria-label={social.name}
            >
              <Icon name={social.icon} class="w-4.5 h-4.5" />
            </a>
          ))}
        </div>



        <!-- Hamburger Button (always visible in full variant) -->
        <button
          id="menu-toggle"
          class="flex md:hidden flex-col justify-center items-center w-10 h-10 bg-white/5 hover:bg-white/10 border border-white/10 rounded-full cursor-pointer transition-colors"
          aria-label="Abrir menú"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <div class="flex flex-col gap-[4px] w-5">
            <span id="ham-1" class="block w-full h-[1.5px] bg-white rounded-full origin-center transition-transform duration-300"></span>
            <span id="ham-2" class="block w-full h-[1.5px] bg-white rounded-full origin-center transition-[transform,opacity] duration-300"></span>
            <span id="ham-3" class="block w-full h-[1.5px] bg-white rounded-full origin-center transition-transform duration-300"></span>
          </div>
        </button>
      </div>
    </div>
  )}
</header>

<!-- ══════════════════════════════════════════
     MOBILE NAV DRAWER (App style, dark, elegant)
     ════════════════════════════════════════════ -->

<!-- Blur overlay -->
<div
  id="menu-overlay"
  class="fixed inset-0 z-[110] bg-black/75 opacity-0 pointer-events-none transition-opacity duration-500 backdrop-blur-md"
  aria-hidden="true"
>
</div>

<!-- Sliding Panel -->
<div
  id="mobile-menu"
  class="fixed  top-0 right-0 z-[120] h-full w-[310px] bg-primary border-l border-white/10 shadow-2xl translate-x-full transition-transform duration-500 ease-in-out flex flex-col justify-between"
  aria-hidden="true"
  role="dialog"
  aria-label="Menú de navegación móvil"
>

      <button
      id="menu-close"
      class="flex absolute top-4 right-4 items-center justify-center w-9 h-9 rounded-full bg-white/5 border border-white/10 text-white/70 hover:text-accent hover:bg-white/10 hover:border-accent/20 transition-all duration-200 cursor-pointer"
      aria-label="Cerrar menú"
    >
      <Icon name="lucide:x" class="w-5 h-5" />
    </button>

  <!-- Mobile Menu Links with Subtitles & Icons -->
  <nav class="flex-1  px-4 py-6 overflow-y-auto" aria-label="Navegación móvil">
    <ul role="list" class="list-none m-0 p-0 flex flex-col gap-2">
      {
        navConfig.links.map((link) => {
          const isLinkActive = cleanPath === link.href.replace(/\/$/, "") || (link.href === "/" && cleanPath === "");
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "flex items-center justify-between p-3.5 rounded-xl border border-transparent transition-all duration-300 group",
                  isLinkActive
                    ? "bg-accent/15 border-accent/20 text-accent font-bold shadow-sm"
                    : "text-white/80 hover:text-white hover:bg-white/5",
                ]}
              >
                <div class="flex items-center gap-3.5">
                  <div class:list={[
                    "w-9 h-9 rounded-xl flex items-center justify-center transition-all duration-300",
                    isLinkActive ? "bg-accent/20 text-accent" : "bg-white/5 text-white/50 group-hover:text-accent group-hover:bg-accent/10"
                  ]}>
                    <Icon name={link.icon} class="w-4.5 h-4.5" />
                  </div>
                  <div class="flex flex-col">
                    <span class="text-sm font-semibold tracking-wide">{link.label}</span>
                    <span class="text-[10px] text-white/40 font-medium group-hover:text-white/75 transition-colors">{link.subtitle}</span>
                  </div>
                </div>
                
                <Icon 
                  name="lucide:chevron-right" 
                  class:list={[
                    "w-4 h-4 transition-transform duration-300 group-hover:translate-x-1",
                    isLinkActive ? "text-accent" : "text-white/20 group-hover:text-white/60"
                  ]} 
                />
              </a>
            </li>
          );
        })
      }
    </ul>
  </nav>

  <!-- Mobile Drawer Footer (Socials, Contacts & CTA) -->
  <div class="p-6 border-t border-white/5 bg-black/20 flex flex-col gap-5">
    <!-- Contact Address and Email -->
    <div class="flex flex-col gap-2.5">
      <a
        href={`mailto:${navConfig.contact.email}`}
        class="flex items-center gap-3 text-xs text-white/60 hover:text-accent transition-colors"
      >
        <Icon name="lucide:mail" class="w-4 h-4 text-accent" />
        <span>{navConfig.contact.email}</span>
      </a>
      <div class="flex items-center gap-3 text-xs text-white/60">
        <Icon name="lucide:map-pin" class="w-4 h-4 text-accent" />
        <span>{navConfig.contact.address}</span>
      </div>
    </div>

    <!-- Social Media Row -->
    <div class="flex items-center gap-3">
      {navConfig.socials.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-1 flex items-center justify-center gap-2 py-2 px-3 rounded-lg bg-white/5 border border-white/10 text-xs text-white/80 hover:text-accent hover:bg-white/10 hover:border-accent/20 transition-all duration-300"
        >
          <Icon name={social.icon} class="w-4 h-4" />
          <span>{social.name}</span>
        </a>
      ))}
    </div>

  </div>
</div>

<script>
  function initHeader() {
    const header = document.getElementById("site-header");
    const container = document.getElementById("header-container");
    const toggle = document.getElementById("menu-toggle");
    const closeBtn = document.getElementById("menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const overlay = document.getElementById("menu-overlay");

    const ham1 = document.getElementById("ham-1");
    const ham2 = document.getElementById("ham-2");
    const ham3 = document.getElementById("ham-3");

    if (!header || !container || !toggle || !closeBtn || !mobileMenu || !overlay || !ham1 || !ham2 || !ham3) return;

    // ── Dynamic Scroll Behavior (Disabled) ──────────────────

    // ── Drawer Panel State management ─────────────
    function openMenu() {
      mobileMenu.classList.remove("translate-x-full");
      mobileMenu.setAttribute("aria-hidden", "false");
      overlay.classList.remove("opacity-0", "pointer-events-none");
      overlay.classList.add("opacity-100");
      toggle.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";

      // Animate hamburger to X
      ham1.style.transform = "translateY(5.5px) rotate(45deg)";
      ham2.style.opacity = "0";
      ham2.style.transform = "scaleX(0)";
      ham3.style.transform = "translateY(-5.5px) rotate(-45deg)";
    }

    function closeMenu() {
      mobileMenu.classList.add("translate-x-full");
      mobileMenu.setAttribute("aria-hidden", "true");
      overlay.classList.add("opacity-0", "pointer-events-none");
      overlay.classList.remove("opacity-100");
      toggle.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";

      // Reset hamburger lines
      ham1.style.transform = "";
      ham2.style.opacity = "";
      ham2.style.transform = "";
      ham3.style.transform = "";
    }

    toggle.addEventListener("click", () => {
      const isOpen = !mobileMenu.classList.contains("translate-x-full");
      isOpen ? closeMenu() : openMenu();
    });

    closeBtn.addEventListener("click", closeMenu);
    overlay.addEventListener("click", closeMenu);

    // Auto close drawer on navigation link clicks
    mobileMenu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });
  }

  // Bind to Astro view transition page swaps
  document.addEventListener("astro:page-load", initHeader);
  // Initial document execution
  initHeader();
</script>
