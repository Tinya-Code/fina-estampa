---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center" | "right";
  className?: string;
}

const { title, subtitle, align = "center", className = "" } = Astro.props;

const alignmentClasses = {
  left: "text-left items-start",
  center: "text-center items-center",
  right: "text-right items-end",
};
---

<div class={`flex flex-col  gap-2 ${alignmentClasses[align]} ${className}`}>
  {
    subtitle && (
      <span class="text-xs md:text-sm font-semibold tracking-[0.2em] text-orange-600 uppercase">
        {subtitle}
      </span>
    )
  }

  <h2
    class="text-3xl w-auto md:text-4xl font-extrabold text-neutral-800 leading-tight tracking-tight relative pb-4"
  >
    {title}
    <span
      class={`absolute bottom-0 h-1 w-16 bg-gradient-to-r from-orange-600 to-amber-500 rounded-full ${
        align === "center"
          ? "left-1/2 -translate-x-1/2"
          : align === "right"
            ? "right-0"
            : "left-0"
      }`}></span>
  </h2>
</div>
