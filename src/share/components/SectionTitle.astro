---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center" | "right";
  className?: string;
  classTitle?: string;
}

const {
  title,
  subtitle,
  align = "center",
  className = "",
  classTitle = "text-3xl md:text-4xl",
} = Astro.props;

const alignmentClasses = {
  left: "text-left items-start",
  center: "text-center items-center",
  right: "text-right items-end",
};
---

<div class={`flex flex-col  gap-2 ${alignmentClasses[align]} ${className}`}>
  {
    subtitle && (
      <span class="text-xs md:text-sm font-display tracking-[0.2em] text-accent ">
        {subtitle.toUpperCase()}
      </span>
    )
  }

  <h2
    class={` w-auto  font-display text-primary leading-tight tracking-tight relative pb-4 ${classTitle}`}
  >
    {title}
    <span
      class={`absolute bottom-0 h-1 w-16 bg-accent rounded-full ${
        align === "center"
          ? "left-1/2 -translate-x-1/2"
          : align === "right"
            ? "right-0"
            : "left-0"
      }`}></span>
  </h2>
</div>
