---
import Layout from "../layouts/Layout.astro";
import { HeaderComponent } from "../share/components-angular/header/header.component";
import { HeroSliderComponent } from "../share/components-angular/hero-slider/hero-slider.component";
import AboutSection from "../share/sections/home/AboutSection.astro";
import BarSection from "../share/sections/home/BarSection.astro";
import ContactSection from "../share/sections/home/ContactSection.astro";
import { EVENTS_CONTENT } from "../data/events/events-content";
import { EventsGalleryComponent } from "../share/components-angular/events-gallery/events-gallery.component";
import FAQAccordion from "../share/sections/events/FAQAccordion.astro";
import Footer from "../share/components/Footer.astro";

import FoodSection from "../share/sections/home/FoodSection.astro";
---

<Layout
  title="Inicio"
  description="Bienvenido a Fina Estampa..."
  keywords="restaurante, criollo, cieneguilla"
>
  <HeaderComponent client:load />

  <HeroSliderComponent
    client:load
    slides={[
      {
        image: "/images/portada-fina-estampa.png",
        logo: "/fina-logo.svg",


  
      },
      {
        image: "/images/restaurant/fina-estampa-banner.png",
        logo: "/fina-logo.svg",

   
      },
      {
        image: "/images/restaurant/espacio-aire-libre.png",
        logo: "/fina-logo.svg",
  
  
      },
    ]}
    autoSlideInterval={5000}
    overlay={true}
    overlayOpacity={0.35}
  />

  <AboutSection />
  <FoodSection />
  <BarSection />
 <EventsGalleryComponent
    client:load

    title={EVENTS_CONTENT.gallery.title}
    subtitle={EVENTS_CONTENT.gallery.subtitle}
    cta={EVENTS_CONTENT.gallery.cta}
  />
     <FAQAccordion
    title={EVENTS_CONTENT.faq.title}
    subtitle={EVENTS_CONTENT.faq.subtitle}
    questions={EVENTS_CONTENT.faq.questions}
    cta={EVENTS_CONTENT.faq.cta}
  />

  <ContactSection />

  <Footer />
</Layout>
