---
import Layout from "../layouts/Layout.astro";
import Header from "../share/components/Header.astro";
import Hero from "../share/components/Hero.astro";
import AboutSection from "../share/sections/home/AboutSection.astro";
import BarSection from "../share/sections/home/BarSection.astro";
import ContactSection from "../share/sections/home/ContactSection.astro";
import EventSection from "../share/sections/home/EventSection.astro";
import FoodSection from "../share/sections/home/FoodSection.astro";
---

<Layout
  title="Inicio"
  description="Bienvenido a Fina Estampa..."
  keywords="restaurante, criollo, cieneguilla"
>
  <Header />
  <Hero
    slides={[
      {
        image: "/images/portada-fina-estampa.png",
        logo: "/fina-logo.svg",
        title: "Fina Estampa",
        subtitle: "Restaurante Criollo en Cieneguilla",
        cta: {
          text: "Ver Menú",
          link: "/menu-desayunos-cocteles",
          variant: "primary",
        },
      },
      {
        image: "/images/portada-fina-estampa.png",
        logo: "/fina-logo.svg",
        title: "Sabor Tradicional",
        subtitle: "Comida Peruana Auténtica",
        cta: {
          text: "Reservar",
          link: "/contacto",
          variant: "primary",
        },
      },
      {
        image: "/images/portada-fina-estampa.png",
        logo: "/fina-logo.svg",
        title: "Ambiente Familiar",
        subtitle: "Disfruta en Familia",
        cta: {
          text: "Contáctanos",
          link: "/contacto",
          variant: "primary",
        },
      },
    ]}
    autoSlideInterval={5000}
    overlay={true}
    overlayOpacity={0.35}
  />
  <AboutSection />
  <FoodSection />
  <BarSection />
  <EventSection />
  <ContactSection />
</Layout>
